# ═══════════════════════════════════════════════════════════════════════════════
#  SERVER ENVIRONMENT — EXAMPLE TEMPLATE
#  Copy this to .env and fill in your actual values.
#  NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000
CORS_ORIGIN=https://YOUR-VERCEL-APP.vercel.app


# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
DB_NAME=nabeeljavedagency


# ── Authentication (JWT) ──────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('base64url')"
JWT_ACCESS_SECRET=
JWT_ACCESS_SECRET_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d


# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=


# ── File Storage (Cloudinary) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=Your Agency <hello@yourdomain.com>


# ── AI Services ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=


# ── Vector Database (Supabase — optional) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=


# ── Cache (Redis — optional) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379


# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://YOUR-RAILWAY-APP.up.railway.app/api/v1/users/auth/google/callback


# ── OAuth — GitHub ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://YOUR-RAILWAY-APP.up.railway.app/api/v1/users/auth/github/callback


# ── OAuth Redirects ───────────────────────────────────────────────────────────
OAUTH_SUCCESS_REDIRECT=https://YOUR-VERCEL-APP.vercel.app/auth/callback
OAUTH_FAILURE_REDIRECT=https://YOUR-VERCEL-APP.vercel.app/auth/callback


# ── Frontend URL (used in email links + 2FA) ──────────────────────────────────
CLIENT_URL=https://YOUR-VERCEL-APP.vercel.app
